# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored.

# Supabase — find these at supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your_anon_key

# Service role key — server-side ONLY. Never expose to the browser.
# Stored in Vercel as an Environment Variable scoped to Server only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key

# Public site URL — used for the magic-link redirect.
# In dev: http://localhost:3000 . In prod: https://sherpakeys.com (or your domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
